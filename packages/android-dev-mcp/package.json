{
  "name": "@tanguito/android-dev-mcp",
  "version": "1.2.0",
  "description": "Generic Android automation and inspection MCP server powered by ADB.",
  "type": "module",
  "license": "MIT",
  "author": "Tanguito86",
  "keywords": [
    "mcp",
    "android",
    "adb",
    "automation",
    "testing",
    "mobile",
    "agent",
    "llm",
    "android-testing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tanguito86/android-dev-mcp.git"
  },
  "homepage": "https://github.com/Tanguito86/android-dev-mcp#readme",
  "bugs": {
    "url": "https://github.com/Tanguito86/android-dev-mcp/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "android-dev-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "config",
    "docs",
    "templates",
    "scripts",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE",
    "ROADMAP.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.js",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "start": "node dist/index.js",
    "doctor": "node scripts/doctor.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanguito/devlab-shared": "workspace:*",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}

{
  "name": "@tanguito/browser-dev-mcp",
  "version": "1.0.0",
  "description": "Desktop browser automation and testing MCP server powered by Playwright — web/canvas game testing, screenshots, evidence capture.",
  "type": "module",
  "license": "MIT",
  "author": "Tanguito86",
  "keywords": [
    "mcp",
    "browser",
    "playwright",
    "automation",
    "testing",
    "canvas",
    "web-game",
    "agent",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tanguito86/browser-dev-mcp.git"
  },
  "homepage": "https://github.com/Tanguito86/browser-dev-mcp#readme",
  "bugs": {
    "url": "https://github.com/Tanguito86/browser-dev-mcp/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "browser-dev-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "profiles",
    "workflows",
    "docs",
    "scripts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.js",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "start": "node dist/index.js",
    "doctor": "node scripts/doctor.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanguito/devlab-shared": "workspace:*",
    "playwright": "^1.55.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}

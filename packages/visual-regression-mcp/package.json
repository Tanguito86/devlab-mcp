{
  "name": "@tanguito/visual-regression-mcp",
  "version": "0.1.0",
  "description": "Visual regression testing MCP server — pixel comparison, diff generation, and markdown reporting for screenshot baselines.",
  "type": "module",
  "license": "MIT",
  "author": "Tanguito86",
  "keywords": [
    "mcp",
    "visual-regression",
    "pixel-diff",
    "screenshot",
    "testing",
    "baseline",
    "comparison",
    "agent",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tanguito86/devlab-mcp.git",
    "directory": "packages/visual-regression-mcp"
  },
  "homepage": "https://github.com/Tanguito86/devlab-mcp#readme",
  "main": "dist/index.js",
  "bin": {
    "visual-regression-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.js",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "start": "node dist/index.js",
    "doctor": "node scripts/doctor.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanguito/devlab-shared": "workspace:*",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
